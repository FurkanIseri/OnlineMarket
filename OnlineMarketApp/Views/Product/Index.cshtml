
@model IEnumerable<Product>
<div class="text-center">
    <table class="table table-striped-columns">
        <thead>
            <tr>
                <td>Product Name</td>
                <td>Category Name</td>
                <td>Explanation</td>
                <td>Price</td>
                <td>Piece</td>
                <td>Origin</td>
                <td class="text-danger">Operations</td>
            </tr>
        </thead>
        <tbody>
            @foreach(Product product in Model){
             <tr>
                <td>@product.ProductName</td>
                <td>@product.Category?.CategoryName</td>
                <td>@product.Explanation</td>
                <td>@product.Price</td>
                <td>@product.Piece</td>
                <td>@product.Origin</td>
                <td>    
                        <a asp-controller="Product" asp-action="Get" asp-route-id="@product.ProductId" class="btn btn-primary">
                         <i class="fa fa-member"></i>
                         Details   
                        </a>
                </td>
            </tr>   
            }
            
        </tbody>
    </table>
</div>
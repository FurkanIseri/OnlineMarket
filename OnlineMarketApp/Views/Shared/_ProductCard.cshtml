
@model Product
<div class="col-sm-12 col-lg-3 my-2">
    <div class="card" style="width: 18rem;">
        <div class="card-header text-center">
            @Model.ProductName
        </div>
        <img src="" class="card-img-top" alt="...">
        <p class="text text-danger text-center lead p-2 my-3" >@Model?.Price.ToString("c2")</p>
        <div class="card-body">
            <p class="card-text">@Model?.Explanation</p>
            <div class="d-flex justify-content-center">
                <div class="btn btn-group">
                    <a asp-controller="Product" asp-action="Get" asp-route-id="@Model.ProductId"
                       class="btn btn-outline-secondary">
                        <i class="fa fa-solid fa-list"></i>
                    </a>
                    <form id="@Model.ProductId" asp-page="/cart" method="post">
                        <input type="hidden" asp-for="ProductId" />
                        <input type="hidden" name="returnUrl" value="@ViewContext.HttpContext.Request.PathAndQuery()" />
                        <button type="submit" class="btn btn-outline-secondary mx-2">
                            <i class="fa fa-cart-plus"></i>
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
@using Entities.Models
@model IEnumerable<Product>

<div class="container-fluid px-4 py-3">
    <h3 class="mb-4 fw-bold">
        <i class="fa fa-star text-warning me-2"></i> Showcase Products
    </h3>

    <div class="row g-3">
        @foreach (var product in Model)
        {
            <div class="col-12 col-sm-6 col-lg-4">
                <div class="card h-100 border-0 shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title fw-semibold">@product.ProductName</h5>
                        <p class="card-text text-muted small">@product.Explanation</p>
                        <div class="d-flex justify-content-between align-items-center mt-3">
                            <span class="badge bg-success fs-6">@product.Price ₺</span>
                            <span class="text-muted small">Stok: @product.Piece</span>
                        </div>
                    </div>
                    <div class="card-footer bg-transparent border-0 pb-3">
                        <a asp-area="Admin" asp-controller="Product" asp-action="Update"
                           asp-route-id="@product.ProductId"
                           class="btn btn-sm btn-outline-primary w-100">
                            <i class="fa fa-edit me-1"></i> Düzenle
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@using Entities.Models
@model Product
<div class="text-center">
    <div class="display-6">
        Update
    </div>
</div>

<form method="post" asp-action="Update" enctype="multipart/form-data">
    <div class="text-danger" asp-validation-summary="All"></div>

    <input type="hidden" asp-for="ProductId" />

    <div class="form-group my-3">
        <label asp-for="CategoryId"></label>
        <input class="form-control" asp-for="CategoryId" />
    </div>
    <div class="form-group my-3">
        <label asp-for="ProductName"></label>
        <input class="form-control" asp-for="ProductName" />
    </div>
    <div class="form-group my-3">
        <label asp-for="Explanation"></label>
        <input class="form-control" asp-for="Explanation" />
    </div>
    <div class="form-group my-3">
        <label asp-for="Price"></label>
        <input class="form-control" asp-for="Price" />
    </div>
    <div class="form-group my-3">
        <label asp-for="Piece"></label>
        <input class="form-control" asp-for="Piece" />
    </div>
    <div class="form-group my-3">
        <label asp-for="Origin"></label>
        <input class="form-control" asp-for="Origin" />
    </div>
    <div class="form-check form-switch">
  <input asp-for="ShowCase" class="form-check-input" type="checkbox" role="switch" id="flexSwitchCheckDefault">
  <label class="form-check-label" for="flexSwitchCheckDefault">Showcase</label>
</div>
    <div class="form-group" my-3>
        <button class="btn btn-primary" type="submit" >Update</button>
        <a asp-action="Index" class="btn btn-outline-primary">Products</a>
    </div>
</form>
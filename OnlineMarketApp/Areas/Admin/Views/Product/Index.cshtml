@model IEnumerable<Product>
<div class="text-center">
    <h1>Products</h1>
</div>
<div class="row">
    <div class="d-flex justify-content-end my-2">
        <div class="text-center my-2">
            <a class="btn btn-success" asp-area="Admin" asp-controller="Product" asp-action="Create">Create</a>
        </div>
    </div>
</div>
<div class="text-center">
    <table class="table table-striped-columns">
        <thead>
            <tr>
                <td>Product Name</td>
                <td>Category Name</td>
                <td>Explanation</td>
                <td>Price</td>
                <td>Piece</td>
                <td>Origin</td>
                <td class="text-danger">Operations</td>
            </tr>
        </thead>
        <tbody>
            @foreach(Product product in Model){
             <tr>
                <td>@product.ProductName</td>
                <td>@product.Category?.CategoryName</td>
                <td>@product.Explanation</td>
                <td>@product.Price</td>
                <td>@product.Piece</td>
                <td>@product.Origin</td>
                <td>    
                        <a asp-area="Admin"  asp-controller="Product" asp-action="Update" asp-route-id="@product.ProductId" class="btn btn-warning">
                        <i class="fa-solid fa-arrow-rotate-right"></i>
                        Update   
                        </a>
                        <a asp-area="Admin"  asp-controller="Product" asp-action="Delete" asp-route-id="@product.ProductId" class="btn btn-danger">
                        <i class="fa-solid fa-arrow-rotate-right"></i>
                        Delete   
                        </a>
                </td>
            </tr>   
            }
            
        </tbody>
    </table>
</div>
@model Category
<div class="text-center">
    <div class="display-6">
        Create
    </div>
</div>

<form method="post" asp-area="Admin" asp-controller="Category" asp-action="Create" enctype="multipart/form-data">
    <div class="text-danger" asp-validation-summary="All"></div>

    <div class="form-group my-3">
        <label asp-for="CategoryName"></label>
        <input class="form-control" asp-for="CategoryName">
    </div>
    <div class="form-group my-3" >
        <button class="btn btn-primary form-group" type="submit">
            Save
        </button>
        <a asp-action="Index" class="btn btn-outline-primary">Categories</a>
    </div>
</form>